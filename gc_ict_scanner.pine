//@version=5
indicator("GC ICT SMC Scanner", overlay=true, max_boxes_count=100, max_labels_count=200, max_lines_count=100)

// ══════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════
grpStructure = "Market Structure"
swingLen     = input.int(10,  "Swing Pivot Length",         group=grpStructure, minval=3)

grpOB        = "Order Blocks"
obLookback   = input.int(3,   "OB Formation Lookback",      group=grpOB, minval=1, maxval=10)
extendBars   = input.int(40,  "Extend OB Boxes (bars)",     group=grpOB, minval=5)

grpEMA       = "EMA Trend Filter"
ema1Len      = input.int(20,  "Fast EMA",                   group=grpEMA)
ema2Len      = input.int(50,  "Mid EMA",                    group=grpEMA)
ema3Len      = input.int(200, "Slow EMA",                   group=grpEMA)

grpSession   = "Sessions"
showLondon   = input.bool(true, "Highlight London Session", group=grpSession)
// London = 02:00–05:00 EST (07:00–10:00 GMT)
londonStart  = input.int(2,  "London Start Hour (EST)",     group=grpSession, minval=0, maxval=23)
londonEnd    = input.int(5,  "London End Hour (EST)",       group=grpSession, minval=0, maxval=23)
// New York = 09:30–12:00 EST
nyStart      = input.int(9,  "NY Start Hour (EST)",         group=grpSession, minval=0, maxval=23)
nyEnd        = input.int(12, "NY End Hour (EST)",           group=grpSession, minval=0, maxval=23)

grpLiq       = "Liquidity"
showLiq      = input.bool(true, "Show BSL / SSL Liquidity Lines", group=grpLiq)
liqTolerance = input.float(0.15, "Equal H/L Tolerance (% of ATR)", group=grpLiq, minval=0.05, maxval=1.0, step=0.05)
liqExtend    = input.int(60,  "Extend Liquidity Lines (bars)",     group=grpLiq, minval=10)
markSweeps   = input.bool(true, "Mark Liquidity Sweeps",           group=grpLiq)

grpDisplay   = "Display"
showSignals  = input.bool(true, "Show Entry Signals",       group=grpDisplay)
showFVG      = input.bool(true, "Show Fair Value Gaps",     group=grpDisplay)

// ══════════════════════════════════════════════════════════════
// EMA RIBBON
// ══════════════════════════════════════════════════════════════
ema1 = ta.ema(close, ema1Len)
ema2 = ta.ema(close, ema2Len)
ema3 = ta.ema(close, ema3Len)

bearishBias = ema1 < ema2 and ema2 < ema3
bullishBias = ema1 > ema2 and ema2 > ema3

emaColor = bearishBias ? color.red : bullishBias ? color.green : color.gray

plot(ema1, "EMA 20",  color=emaColor,        linewidth=1)
plot(ema2, "EMA 50",  color=emaColor,        linewidth=2)
plot(ema3, "EMA 200", color=color.new(color.orange, 20), linewidth=2)

// EMA ribbon fill
ema1Plot = plot(ema1, display=display.none)
ema2Plot = plot(ema2, display=display.none)
fill(ema1Plot, ema2Plot, color=color.new(emaColor, 85), title="EMA Ribbon Fill")

// ══════════════════════════════════════════════════════════════
// SESSION HIGHLIGHTING
// ══════════════════════════════════════════════════════════════
inLondon = hour(time, "America/New_York") >= londonStart and hour(time, "America/New_York") < londonEnd
inNY     = hour(time, "America/New_York") >= nyStart     and hour(time, "America/New_York") < nyEnd

bgcolor(showLondon and inLondon ? color.new(color.blue,  92) : na, title="London Session BG")
bgcolor(showLondon and inNY     ? color.new(color.green, 92) : na, title="NY Session BG")

// ══════════════════════════════════════════════════════════════
// MARKET STRUCTURE — SWING HIGHS / LOWS
// ══════════════════════════════════════════════════════════════
swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow  = ta.pivotlow (low,  swingLen, swingLen)

var float sh1 = na
var float sh2 = na
var float sl1 = na
var float sl2 = na
var int   shBar1 = na
var int   shBar2 = na
var int   slBar1 = na
var int   slBar2 = na

if not na(swingHigh)
    sh2 := sh1
    sh1 := swingHigh
    shBar2 := shBar1
    shBar1 := bar_index[swingLen]

if not na(swingLow)
    sl2 := sl1
    sl1 := swingLow
    slBar2 := slBar1
    slBar1 := bar_index[swingLen]

isLH = not na(sh1) and not na(sh2) and sh1 < sh2
isLL = not na(sl1) and not na(sl2) and sl1 < sl2
isHH = not na(sh1) and not na(sh2) and sh1 > sh2
isHL = not na(sl1) and not na(sl2) and sl1 > sl2

if not na(swingHigh)
    lbl = isLH ? "LH" : "HH"
    col = isLH ? color.red : color.green
    label.new(bar_index[swingLen], high[swingLen] + ta.atr(14) * 0.3, lbl, style=label.style_label_down, color=col, textcolor=color.white, size=size.small)

if not na(swingLow)
    lbl = isLL ? "LL" : "HL"
    col = isLL ? color.red : color.green
    label.new(bar_index[swingLen], low[swingLen] - ta.atr(14) * 0.3, lbl, style=label.style_label_up, color=col, textcolor=color.white, size=size.small)

// ══════════════════════════════════════════════════════════════
// ORDER BLOCK DETECTION
// ══════════════════════════════════════════════════════════════
// Bearish OB  = last bullish candle before a bearish impulse move
// Bullish OB  = last bearish candle before a bullish impulse move

isBull = close > open
isBear = close < open

// A "displacement" candle = large bodied candle (body > 60% of ATR)
atr14  = ta.atr(14)
largeBearDisplacement = isBear and (open - close) > atr14 * 0.6
largeBullDisplacement = isBull and (close - open) > atr14 * 0.6

// Bearish OB: bullish candle N bars ago, followed by large bearish displacement now
bearOBFormed = largeBearDisplacement and isBull[obLookback]
bullOBFormed = largeBullDisplacement and isBear[obLookback]

var float bearOBHigh = na
var float bearOBLow  = na
var float bullOBHigh = na
var float bullOBLow  = na
var int   bearOBBar  = na
var int   bullOBBar  = na

if bearOBFormed
    bearOBHigh := high[obLookback]
    bearOBLow  := open[obLookback]
    bearOBBar  := bar_index[obLookback]
    if showFVG
        box.new(bearOBBar, bearOBHigh, bar_index + extendBars, bearOBLow, border_color=color.red, bgcolor=color.new(color.red, 80), border_width=1)

if bullOBFormed
    bullOBHigh := open[obLookback]
    bullOBLow  := low[obLookback]
    bullOBBar  := bar_index[obLookback]
    if showFVG
        box.new(bullOBBar, bullOBHigh, bar_index + extendBars, bullOBLow, border_color=color.green, bgcolor=color.new(color.green, 80), border_width=1)

// ══════════════════════════════════════════════════════════════
// FAIR VALUE GAPS (FVG)
// ══════════════════════════════════════════════════════════════
// Bearish FVG: high[2] < low[0]  →  gap between candle -2 top and candle 0 bottom
bearFVG = showFVG and high[2] < low[0]
bullFVG = showFVG and low[2]  > high[0]

if bearFVG
    box.new(bar_index - 2, low[0], bar_index + extendBars, high[2], border_color=color.new(color.red, 60), bgcolor=color.new(color.red, 88), border_width=1, border_style=line.style_dotted)

if bullFVG
    box.new(bar_index - 2, low[2], bar_index + extendBars, high[0], border_color=color.new(color.green, 60), bgcolor=color.new(color.green, 88), border_width=1, border_style=line.style_dotted)

// ══════════════════════════════════════════════════════════════
// LIQUIDITY — BSL (Buy-Side) / SSL (Sell-Side)
// ══════════════════════════════════════════════════════════════
// BSL = equal highs where short stops + breakout buy orders rest (price wants to sweep UP)
// SSL = equal lows where long stops + breakout sell orders rest (price wants to sweep DOWN)
var float bslLevel  = na
var float sslLevel  = na
var int   bslBar    = na
var int   sslBar    = na
var line  bslLine   = na
var line  sslLine   = na
var label bslLabel  = na
var label sslLabel  = na
var bool  bslSwept  = false
var bool  sslSwept  = false

liqTol = ta.atr(14) * liqTolerance

// Detect BSL: EVERY confirmed swing high is buy-side liquidity. Equal highs = stronger (marked differently)
if not na(swingHigh)
    isEqualHigh = not na(sh2) and math.abs(swingHigh - sh2) <= liqTol
    bslLevel := isEqualHigh ? math.max(swingHigh, sh2) : swingHigh
    bslBar   := bar_index[swingLen]
    bslSwept := false
    if showLiq
        if not na(bslLine)
            line.delete(bslLine)
            label.delete(bslLabel)
        lineColor = isEqualHigh ? color.aqua : color.new(color.aqua, 40)
        lineWidth = isEqualHigh ? 2 : 1
        labelText = isEqualHigh ? "BSL == " + str.tostring(bslLevel, "#.##") : "BSL " + str.tostring(bslLevel, "#.##")
        bslLine  := line.new(bslBar, bslLevel, bar_index + liqExtend, bslLevel, color=lineColor, width=lineWidth, style=line.style_solid)
        bslLabel := label.new(bar_index + liqExtend, bslLevel, labelText, style=label.style_label_left, color=lineColor, textcolor=color.white, size=size.small)

// Detect SSL: EVERY confirmed swing low is sell-side liquidity. Equal lows = stronger
if not na(swingLow)
    isEqualLow = not na(sl2) and math.abs(swingLow - sl2) <= liqTol
    sslLevel := isEqualLow ? math.min(swingLow, sl2) : swingLow
    sslBar   := bar_index[swingLen]
    sslSwept := false
    if showLiq
        if not na(sslLine)
            line.delete(sslLine)
            label.delete(sslLabel)
        lineColor = isEqualLow ? color.fuchsia : color.new(color.fuchsia, 40)
        lineWidth = isEqualLow ? 2 : 1
        labelText = isEqualLow ? "SSL == " + str.tostring(sslLevel, "#.##") : "SSL " + str.tostring(sslLevel, "#.##")
        sslLine  := line.new(sslBar, sslLevel, bar_index + liqExtend, sslLevel, color=lineColor, width=lineWidth, style=line.style_solid)
        sslLabel := label.new(bar_index + liqExtend, sslLevel, labelText, style=label.style_label_left, color=lineColor, textcolor=color.white, size=size.small)

// Sweep detection: wick beyond level then close back inside (classic liquidity grab)
bslSweep = not na(bslLevel) and not bslSwept and high > bslLevel and close < bslLevel
sslSweep = not na(sslLevel) and not sslSwept and low  < sslLevel and close > sslLevel

if bslSweep
    bslSwept := true
    if markSweeps
        label.new(bar_index, high, "BSL SWEEP", style=label.style_label_down, color=color.new(color.aqua, 20), textcolor=color.white, size=size.small)

if sslSweep
    sslSwept := true
    if markSweeps
        label.new(bar_index, low, "SSL SWEEP", style=label.style_label_up, color=color.new(color.fuchsia, 20), textcolor=color.white, size=size.small)

// ══════════════════════════════════════════════════════════════
// SIGNAL CONDITIONS
// ══════════════════════════════════════════════════════════════
inBearOB = not na(bearOBHigh) and high >= bearOBLow and low <= bearOBHigh
inBullOB = not na(bullOBHigh) and high >= bullOBLow and low <= bullOBHigh

// SELL: (Bearish OB + LH + bearish bias + session)  OR  (BSL swept + bearish bias + session)
sellSignal = (inBearOB and isLH and bearishBias and (inLondon or inNY)) or (bslSweep and bearishBias and (inLondon or inNY))

// BUY: (Bullish OB + HL + bullish bias + session)  OR  (SSL swept + bullish bias + session)
buySignal  = (inBullOB and isHL and bullishBias and (inLondon or inNY)) or (sslSweep and bullishBias and (inLondon or inNY))

plotshape(showSignals and sellSignal, "SELL", shape.labeldown, location.abovebar, color.red, text="SELL", textcolor=color.white, size=size.normal)
plotshape(showSignals and buySignal,  "BUY",  shape.labelup,   location.belowbar, color.green, text="BUY",  textcolor=color.white, size=size.normal)

// ══════════════════════════════════════════════════════════════
// ALERT CONDITIONS  (set these up in TradingView → Alerts)
// ══════════════════════════════════════════════════════════════
alertcondition(sellSignal, "GC SELL - OB + LH + London/NY", "GC SELL SIGNAL | Price: {{close}} | Bearish OB + Lower High + Session Active")
alertcondition(buySignal, "GC BUY - OB + HL + London/NY", "GC BUY SIGNAL | Price: {{close}} | Bullish OB + Higher Low + Session Active")
alertcondition(inBearOB and (inLondon or inNY), "GC Price Entering Bearish OB", "GC ALERT | Price entering Bearish Order Block at {{close}} during active session")
alertcondition(bearOBFormed, "New Bearish OB Formed", "GC | New Bearish Order Block formed at {{close}} | Top: {{high}} Bot: {{open}}")
alertcondition(bslSweep, "BSL Sweep - Buy-Side Liquidity Grab", "GC | BSL SWEPT at {{high}} - shorts stopped out, watch for reversal SHORT")
alertcondition(sslSweep, "SSL Sweep - Sell-Side Liquidity Grab", "GC | SSL SWEPT at {{low}} - longs stopped out, watch for reversal LONG")
